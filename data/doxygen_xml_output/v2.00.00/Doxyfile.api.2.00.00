    GENERATE_XML     = YES
    GENERATE_HTML    = NO
    GENERATE_LATEX   = NO
    GENERATE_RTF     = NO
    GENERATE_MAN     = NO
    GENERATE_XML     = YES
    XML_OUTPUT       = "xml" # Doxygen will create a 'xml' subfolder in OUTPUT_DIRECTORY

    # Input settings
    INPUT            = "/Users/jordanlee/Documents/GitHub/sdk-rag-agent/data/raw_sdk_docs/sdk_source/v2.00.00/CRSDK"
    FILE_PATTERNS    = *.h *.hpp
    RECURSIVE        = YES

